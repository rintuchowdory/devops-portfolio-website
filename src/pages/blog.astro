---
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = [
  {
    title: "Setting up a CI/CD Pipeline with GitHub Actions",
    date: "2025-06-01",
    tags: ["CI/CD", "GitHub Actions", "DevOps"],
    summary:
      "How I built an automated pipeline that runs tests, builds a Docker image, and pushes it to GHCR on every commit to main.",
    slug: "#",
  },
  {
    title: "Dockerising a FastAPI Application from Scratch",
    date: "2025-05-18",
    tags: ["Docker", "FastAPI", "Python"],
    summary:
      "A step-by-step walkthrough of writing a production-ready Dockerfile for a FastAPI service — multi-stage builds, non-root user, and health checks included.",
    slug: "#",
  },
  {
    title: "Understanding Kubernetes Pods, Deployments, and Services",
    date: "2025-05-05",
    tags: ["Kubernetes", "K8s", "Cloud"],
    summary:
      "My notes from working through the core K8s primitives — what each resource actually does, and when to reach for which one.",
    slug: "#",
  },
  {
    title: "Linux for DevOps: The Commands I Use Every Day",
    date: "2025-04-20",
    tags: ["Linux", "Shell", "DevOps"],
    summary:
      "A personal cheatsheet of bash commands, file-system tricks, and process-management one-liners that save me time every single day.",
    slug: "#",
  },
];
---

<BaseLayout title="Blog | Rintu Chowdory">
  <div class="max-w-6xl mx-auto p-4 md:p-8 space-y-6">

    <!-- Header -->
    <div class="flex items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold">Blog</h1>
        <p class="text-base-content/70">
          Notes, walkthroughs, and lessons from building DevOps projects in public.
        </p>
      </div>
      <a class="btn btn-outline btn-sm" href="/">Home</a>
    </div>

    <!-- Posts grid -->
    <div class="grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <a
          href={post.slug}
          class="card bg-base-100 shadow-xl border border-base-300 hover:border-primary transition-colors group"
        >
          <div class="card-body">
            <div class="flex items-center justify-between mb-1">
              <time class="text-xs text-base-content/50">{post.date}</time>
            </div>
            <h2 class="card-title group-hover:text-primary transition-colors">
              {post.title}
            </h2>
            <p class="text-base-content/70 text-sm">{post.summary}</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {post.tags.map((t) => (
                <span class="badge badge-outline badge-sm">{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Coming soon notice -->
    <div class="alert alert-info">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>Full articles are coming soon. Follow along on <a class="link" href="https://github.com/rintuchowdory" target="_blank" rel="noreferrer">GitHub</a> in the meantime.</span>
    </div>

  </div>
</BaseLayout>
