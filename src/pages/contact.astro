---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Rintu Chowdory">
  <div class="max-w-4xl mx-auto p-4 md:p-8 space-y-6">
    <div class="flex items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold">Contact</h1>
        <p class="text-base-content/70">Links and profiles.</p>
      </div>
      <a class="btn btn-outline btn-sm" href="/">Home</a>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-300">
      <div class="card-body space-y-2">
        <div class="flex items-center justify-between gap-3">
          <span class="font-semibold">GitHub</span>
          <a class="link link-primary" href="https://github.com/rintuchowdory" target="_blank" rel="noreferrer">
            github.com/rintuchowdory
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
