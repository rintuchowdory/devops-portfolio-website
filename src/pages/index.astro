---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Rintu Chowdory | DevOps Portfolio">
  <div class="bg-hero min-h-screen">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid lg:grid-cols-2 gap-8 items-center">

        <div class="glass-panel p-6 md:p-8 text-white">
          <div class="flex items-center justify-between">
            <div class="text-sm opacity-80">DevOps Portfolio Dashboard</div>
            <a class="btn btn-sm btn-outline text-white border-white/30"
               href="https://github.com/rintuchowdory"
               target="_blank" rel="noreferrer">
              GitHub
            </a>
          </div>

          <h1 class="text-4xl font-extrabold mt-6 leading-tight">Rintu Chowdory</h1>
          <p class="mt-2 opacity-80">
            Learning Linux, CI/CD, Docker, Kubernetes, GitHub, and automation by building real projects.
          </p>

          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="glass-panel p-4">
              <div class="text-xs opacity-70">Current Focus</div>
              <div class="font-semibold">DevOps + Cloud</div>
            </div>
            <div class="glass-panel p-4">
              <div class="text-xs opacity-70">Primary Stack</div>
              <div class="font-semibold">FastAPI, Docker</div>
            </div>
            <div class="glass-panel p-4">
              <div class="text-xs opacity-70">CI/CD</div>
              <div class="font-semibold">GitHub Actions</div>
            </div>
            <div class="glass-panel p-4">
              <div class="text-xs opacity-70">Next</div>
              <div class="font-semibold">K8s + Helm</div>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn border-0 text-white"
               style="background: linear-gradient(90deg,#a855f7,#ec4899);"
               href="/projects">
              View Projects
            </a>
            <a class="btn btn-ghost text-white/90" href="/roadmap">Roadmap</a>
            <a class="btn btn-ghost text-white/90" href="/contact">Contact</a>
          </div>

          <div class="mt-8">
            <div class="text-sm opacity-80 mb-2">Skills progress</div>

            <div class="space-y-3">
              <div>
                <div class="flex justify-between text-xs opacity-80"><span>Linux</span><span>70%</span></div>
                <progress class="progress progress-secondary w-full" value="70" max="100"></progress>
              </div>
              <div>
                <div class="flex justify-between text-xs opacity-80"><span>Docker</span><span>65%</span></div>
                <progress class="progress progress-accent w-full" value="65" max="100"></progress>
              </div>
              <div>
                <div class="flex justify-between text-xs opacity-80"><span>CI/CD</span><span>60%</span></div>
                <progress class="progress progress-info w-full" value="60" max="100"></progress>
              </div>
              <div>
                <div class="flex justify-between text-xs opacity-80"><span>Kubernetes</span><span>40%</span></div>
                <progress class="progress progress-primary w-full" value="40" max="100"></progress>
              </div>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="rounded-3xl overflow-hidden shadow-2xl border border-white/10">
            <div class="h-[520px] bg-cover bg-center"
                 style="background-image:url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=1600&q=80');">
              <div class="h-full w-full bg-black/50 flex items-end">
                <div class="p-6 md:p-8 text-white">
                  <div class="text-sm opacity-80">Featured project</div>
                  <div class="text-3xl font-bold">FastAPI Microservice</div>
                  <p class="opacity-80 mt-1">Tests, Docker image build, and GHCR publish via GitHub Actions.</p>

                  <div class="mt-4 flex gap-3">
                    <a class="btn btn-sm btn-outline text-white border-white/30"
                       href="https://github.com/rintuchowdory/devops-portfolio-microservice"
                       target="_blank" rel="noreferrer">
                      View Repo
                    </a>
                    <a class="btn btn-sm border-0 text-white"
                       style="background: linear-gradient(90deg,#3b82f6,#22c55e);"
                       href="/projects">
                      See all
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="glass-panel text-white p-4 md:p-5 max-w-sm absolute -bottom-6 left-6">
            <div class="text-sm opacity-80">Portfolio goal</div>
            <div class="font-semibold">Build real CI/CD + Kubernetes projects for my CV.</div>
            <div class="text-xs opacity-70 mt-1">Next: deploy the API and show live status on the dashboard.</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
