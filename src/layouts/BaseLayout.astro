---
import "../styles/global.css";

const { title = "DevOps Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="night">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-200">
    <slot />
  </body>
</html>
